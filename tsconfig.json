{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ESNext"],
    "target": "esnext",
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "declaration": true, // Type Definition Files
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "verbatimModuleSyntax": true // Avisar cuando falten extensiones
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
